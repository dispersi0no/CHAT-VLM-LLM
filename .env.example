# Конфигурация окружения для ChatVLMLLM

# =============================================================================
# Настройки модели
# =============================================================================
# Директория кэша моделей HuggingFace
MODEL_CACHE_DIR=~/.cache/huggingface
# Максимальный размер изображения в байтах (10 MB)
MAX_IMAGE_SIZE=10485760

# =============================================================================
# Настройки устройства
# =============================================================================
CUDA_VISIBLE_DEVICES=0
USE_GPU=true
DEVICE=cuda  # cuda, cpu, или mps

# =============================================================================
# Настройки API
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000

# =============================================================================
# Настройки безопасности
# =============================================================================
# CORS: разделённый запятыми список разрешённых origins (читается в api.py)
CORS_ORIGINS=http://localhost:8501,http://localhost:3000,http://127.0.0.1:8501

# Rate limiting: запросов в минуту на IP (читается в api.py)
RATE_LIMIT=60

# =============================================================================
# Настройки Streamlit
# =============================================================================
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=localhost

# =============================================================================
# Логирование
# =============================================================================
LOG_LEVEL=INFO
LOGS_DIR=./logs

# =============================================================================
# Производительность
# =============================================================================
USE_INT4_QUANTIZATION=false
OPTIMIZE_MEMORY=true

# =============================================================================
# Пути
# =============================================================================
RESULTS_DIR=./results
EXAMPLES_DIR=./examples
